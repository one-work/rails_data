<td><%= model.id %></td>
<td><%= simple_format(model.parameters) %></td>
<td><%= model.headers.join(',') %></td>
<td><%= model.timestamp %></td>
<td id="done_<%= model.id %>">
  <% if model.done %>
    <%= svg_tag 'check', class: 'icon is-small text-success' %>
  <% else %>
    <%= svg_tag 'xmark', class: 'icon is-small text-danger' %>
  <% end %>
</td>
